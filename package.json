{
  "name": "restore-base",
  "version": "0.1.0",
  "description": "A small, self-hostable Discord bot wrapper inspired by RestoreBase and restorebase.net.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepack": "npm run build"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "restorebase",
    "bot-wrapper"
  ],
  "author": "RestoreBase",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zombyrra/Restore-Base.git"
  },
  "bugs": {
    "url": "https://github.com/zombyrra/Restore-Base/issues"
  },
  "homepage": "https://restorebase.net",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
